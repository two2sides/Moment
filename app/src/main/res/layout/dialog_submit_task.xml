<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@drawable/bg_card_cute">

        <TextView
            android:id="@+id/tvSubmitTaskTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etSubmitText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/MomentInput"
            android:hint="@string/submit_markdown_hint"
            android:inputType="textMultiLine"
            android:minLines="6"
            android:gravity="top|start"
            android:visibility="gone"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnPickImage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/MomentSecondaryButton"
            android:text="@string/insert_markdown_image"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvMarkdownTip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/markdown_tip"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:visibility="visible" />

        <TextView
            android:id="@+id/tvImagePicked"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>

